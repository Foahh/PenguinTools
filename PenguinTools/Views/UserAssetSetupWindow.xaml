<Window
    ResizeMode="NoResize"
    ShowInTaskbar="True"
    SizeToContent="WidthAndHeight"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d"
    x:Class="PenguinTools.Views.UserAssetSetupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:res="clr-namespace:PenguinTools.Resources"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Border MinWidth="420" Padding="20">
        <StackPanel>
            <TextBlock
                FontSize="14"
                Margin="0,0,0,12"
                Text="{Binding ExplanationText}"
                TextWrapping="Wrap" />
            <StackPanel Margin="0,0,0,12" Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock
                    FontWeight="SemiBold"
                    Margin="0,0,0,8"
                    Text="{Binding ProcessingText}"
                    TextWrapping="Wrap" />
                <ProgressBar Height="6" IsIndeterminate="True" />
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Command="{Binding BrowseGameFolderCommand}"
                    Content="{x:Static res:Strings.UserAssetSetup_Browse_install}"
                    IsDefault="True"
                    Margin="0,0,8,0"
                    MinWidth="140"
                    Padding="12,6" />
                <Button
                    Command="{Binding SkipCommand}"
                    Content="{x:Static res:Strings.UserAssetSetup_Skip}"
                    IsCancel="True"
                    MinWidth="88"
                    Padding="12,6" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>