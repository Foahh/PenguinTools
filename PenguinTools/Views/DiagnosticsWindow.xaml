<Window
    Height="720"
    MinHeight="420"
    MinWidth="560"
    Style="{DynamicResource DialogWindowStyle}"
    Title="{Binding Title}"
    Width="980"
    WindowStartupLocation="CenterOwner"
    d:DataContext="{d:DesignInstance views:DiagnosticsWindowViewModel}"
    mc:Ignorable="d"
    x:Class="PenguinTools.Views.DiagnosticsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:behaviors="clr-namespace:PenguinTools.Behaviors"
    xmlns:controls="clr-namespace:PenguinTools.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:diagnostic="clr-namespace:PenguinTools.Core.Diagnostic;assembly=PenguinTools.Core"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:res="clr-namespace:PenguinTools.Resources"
    xmlns:views="clr-namespace:PenguinTools.Views"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.Resources>
        <Style TargetType="Button" x:Key="FilterButtonStyle">
            <Setter Property="Background" Value="#F4F6FA" />
            <Setter Property="BorderBrush" Value="#D6DCE6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="18,4" />
        </Style>

        <Style TargetType="Button" x:Key="FooterButtonStyle">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="24,2" />
        </Style>

        <Style TargetType="TextBlock" x:Key="SeverityTextStyle">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1D4ED8" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static diagnostic:Severity.Error}">
                    <Setter Property="Text" Value="{x:Static res:Strings.Diagnostic_Severity_Error}" />
                    <Setter Property="Foreground" Value="#B42318" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static diagnostic:Severity.Warning}">
                    <Setter Property="Text" Value="{x:Static res:Strings.Diagnostic_Severity_Warning}" />
                    <Setter Property="Foreground" Value="#B54708" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static diagnostic:Severity.Information}">
                    <Setter Property="Text" Value="{x:Static res:Strings.Diagnostic_Severity_Information}" />
                    <Setter Property="Foreground" Value="#1D4ED8" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="6" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Button
                    Command="{Binding SetFilterCommand}"
                    CommandParameter="All"
                    Content="{x:Static res:Strings.Diagnostic_Filter_All}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource FilterButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentFilter}" Value="{x:Static views:DiagnosticFilter.All}">
                                    <Setter Property="Background" Value="#E8F1FF" />
                                    <Setter Property="BorderBrush" Value="#60A5FA" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button
                    Command="{Binding SetFilterCommand}"
                    CommandParameter="Errors"
                    Content="{x:Static res:Strings.Diagnostic_Filter_Errors}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource FilterButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentFilter}" Value="{x:Static views:DiagnosticFilter.Errors}">
                                    <Setter Property="Background" Value="#FDE7E9" />
                                    <Setter Property="BorderBrush" Value="#F97066" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button
                    Command="{Binding SetFilterCommand}"
                    CommandParameter="Warnings"
                    Content="{x:Static res:Strings.Diagnostic_Filter_Warnings}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource FilterButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentFilter}" Value="{x:Static views:DiagnosticFilter.Warnings}">
                                    <Setter Property="Background" Value="#FFF4CE" />
                                    <Setter Property="BorderBrush" Value="#F79009" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button
                    Command="{Binding SetFilterCommand}"
                    CommandParameter="Information"
                    Content="{x:Static res:Strings.Diagnostic_Filter_Information}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource FilterButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentFilter}" Value="{x:Static views:DiagnosticFilter.Information}">
                                    <Setter Property="Background" Value="#E8F1FF" />
                                    <Setter Property="BorderBrush" Value="#60A5FA" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <TextBlock
                DockPanel.Dock="Right"
                FontWeight="SemiBold"
                Foreground="#4B5563"
                Text="{Binding FilterSummary}"
                VerticalAlignment="Center" />
        </DockPanel>

        <GroupBox Grid.Row="1" Header="{x:Static res:Strings.Title_Diagnostics}">
            <ListView
                ItemsSource="{Binding FilteredDiagnostics}"
                ScrollViewer.CanContentScroll="True"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                SelectedItem="{Binding SelectedDiagnostic}"
                SelectionMode="Single">

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{x:Static res:Strings.Diagnostic_Column_Severity}" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image
                                            Height="12"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Width="12">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static diagnostic:Severity.Error}">
                                                            <Setter Property="Source" Value="{StaticResource ErrorIcon}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static diagnostic:Severity.Warning}">
                                                            <Setter Property="Source" Value="{StaticResource WarningIcon}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static diagnostic:Severity.Information}">
                                                            <Setter Property="Source" Value="{StaticResource InfoIcon}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Style="{StaticResource SeverityTextStyle}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{x:Static res:Strings.Label_Message}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding Message}"
                                        TextWrapping="Wrap"
                                        VerticalAlignment="Center" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{x:Static res:Strings.Diagnostic_Column_Context}" Width="{Binding LocationColumnWidth}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Foreground="#4B5563"
                                        Text="{Binding FormattedLocation}"
                                        TextWrapping="Wrap"
                                        VerticalAlignment="Center" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{x:Static res:Strings.Label_Time}" Width="{Binding TimeColumnWidth}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Foreground="#4B5563"
                                        Text="{Binding FormattedTime}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap"
                                        VerticalAlignment="Center" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <GridSplitter
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            ResizeBehavior="PreviousAndNext"
            ResizeDirection="Rows"
            ShowsPreview="True"
            VerticalAlignment="Center" />

        <GroupBox Grid.Row="3" Header="{x:Static res:Strings.Label_Details}">
            <Grid>
                <TextBlock
                    Foreground="#6B7280"
                    Margin="8"
                    Text="{x:Static res:Strings.Diagnostic_Details_Empty}"
                    TextWrapping="Wrap">
                    <i:Interaction.Behaviors>
                        <behaviors:HideIfNullValueBehavior Invert="True" Value="{Binding SelectedDiagnostic}" />
                    </i:Interaction.Behaviors>
                </TextBlock>

                <controls:ObjectTreeView SelectedObject="{Binding SelectedDiagnostic}">
                    <i:Interaction.Behaviors>
                        <behaviors:HideIfNullValueBehavior Value="{Binding SelectedDiagnostic}" />
                    </i:Interaction.Behaviors>
                </controls:ObjectTreeView>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="4" Style="{StaticResource ActionPanelStyle}">
            <Button
                Command="{Binding CopySelectedCommand}"
                Content="{x:Static res:Strings.Diagnostic_Button_CopySelected}"
                Style="{StaticResource FooterButtonStyle}" />
            <Button
                Command="{Binding CopyAllCommand}"
                Content="{x:Static res:Strings.Diagnostic_Button_CopyShown}"
                Style="{StaticResource FooterButtonStyle}" />
            <Button
                Content="{x:Static res:Strings.Button_Close}"
                IsDefault="True"
                Style="{StaticResource FooterButtonStyle}">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="Click">
                        <i:CallMethodAction MethodName="Close" TargetObject="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Button>
        </StackPanel>
    </Grid>
</Window>
