<UserControl
    MaxWidth="600"
    d:DataContext="{d:DesignInstance Type=viewModels:MiscViewModel}"
    mc:Ignorable="d"
    x:Class="PenguinTools.Views.MiscTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:converters="clr-namespace:PenguinTools.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PenguinTools"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:res="clr-namespace:PenguinTools.i18n;assembly=PenguinTools.i18n"
    xmlns:shell="clr-namespace:PenguinTools.Controls"
    xmlns:viewModels="clr-namespace:PenguinTools.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="{x:Type StackPanel}">
            <Style.Resources>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="Margin" Value="0,4,0,0" />
                </Style>
            </Style.Resources>
        </Style>
        <converters:VersionConverter x:Key="VersionConverter" />
    </UserControl.Resources>

    <shell:TabShell>
        <shell:TabShell.MainContent>
            <StackPanel Margin="8,0,8,8">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        FontSize="14"
                        Foreground="#555"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0"
                        Text="{Binding Source={x:Static local:App.BuildDate}, StringFormat=Foahh @ {0:yyyy/MM/dd}}" />

                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#777"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0"
                        Text="{Binding Source={x:Static local:App.Version}, Converter={StaticResource VersionConverter}}" />
                </StackPanel>
            </StackPanel>
        </shell:TabShell.MainContent>
        <shell:TabShell.FooterContent>
            <StackPanel>
                <Button Command="{Binding OpenUserDataDirectoryCommand}" Content="{x:Static res:Strings.Button_Open_user_data_directory}" />
                <Button Command="{Binding OpenAssetsDirectoryCommand}" Content="{x:Static res:Strings.Button_Open_assets_directory}" />
                <Button Command="{Binding OpenTempDirectoryCommand}" Content="{x:Static res:Strings.Button_Open_temp_directory}" />
                <Button Command="{Binding ExtractAfbFileCommand}" Content="{x:Static res:Strings.Button_Extract_dds_from_afb}" />
                <Button Command="{Binding CollectAssetCommand}" Content="{x:Static res:Strings.Button_Recollect_A000}" />
                <GroupBox Header="{x:Static res:Strings.Label_Language}" Margin="0,4,0,0">
                    <ComboBox
                        DisplayMemberPath="DisplayName"
                        ItemsSource="{Binding AvailableLanguages}"
                        Margin="0,4,0,0"
                        SelectedItem="{Binding SelectedLanguage}" />
                </GroupBox>
            </StackPanel>
        </shell:TabShell.FooterContent>
    </shell:TabShell>
</UserControl>