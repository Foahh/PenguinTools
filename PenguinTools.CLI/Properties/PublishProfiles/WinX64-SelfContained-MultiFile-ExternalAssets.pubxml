<Project>
    <PropertyGroup>
        <Configuration>Release</Configuration>
        <RuntimeIdentifier>win-x64</RuntimeIdentifier>
        <PublishSingleFile>false</PublishSingleFile>
        <SelfContained>true</SelfContained>
        <PublishTrimmed>true</PublishTrimmed>
        <PenguinToolsEmbedInfrastructureAssets>false</PenguinToolsEmbedInfrastructureAssets>
        <PenguinToolsCreateZipPackage>true</PenguinToolsCreateZipPackage>
        <PublishDir>bin\Release\net10.0\publish\WinX64-SelfContained-MultiFile-ExternalAssets\</PublishDir>
        <PenguinToolsPublishZipPath>bin\Release\net10.0\publish\PenguinTools.CLI-win-x64-self-contained-multifile-external.zip</PenguinToolsPublishZipPath>
    </PropertyGroup>
</Project>
