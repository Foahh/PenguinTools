<Project>
    <PropertyGroup>
        <Configuration>Release</Configuration>
        <RuntimeIdentifier>win-x64</RuntimeIdentifier>
        <PublishSingleFile>true</PublishSingleFile>
        <SelfContained>true</SelfContained>
        <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
        <PenguinToolsEmbedInfrastructureAssets>false</PenguinToolsEmbedInfrastructureAssets>
        <PenguinToolsCreateZipPackage>true</PenguinToolsCreateZipPackage>
        <PublishDir>bin\Release\net10.0\publish\WinX64-SelfContained-SingleFile-ExternalAssets\</PublishDir>
        <PenguinToolsPublishZipPath>bin\Release\net10.0\publish\PenguinTools.CLI-win-x64.zip</PenguinToolsPublishZipPath>
    </PropertyGroup>
</Project>
