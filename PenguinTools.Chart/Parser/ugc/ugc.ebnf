(* Umiguri Chart v8 (UGC) — reference grammar
   Source of truth: https://gist.github.com/inonote/5c01e73781cab17765a1d93641d52298)

file         = { line } ;
line         = comment | header | body | blank ;

comment      = "'" , { any-char - EOL } , EOL ;
blank        = EOL ;
header       = "@" , ident , { TAB , field } , EOL ;
body         = parent-line | child-line ;

parent-line  = "#" , bar , "'" , tick , ":" , payload , [ "," , suffix ] , EOL ;
child-line   = "#" , offset-tick , ">" , payload , EOL ;

bar          = digits ;
tick         = digits ;
offset-tick  = digits ;

payload      = type-char , x-b36 , w-b36 , [ extras ] ;
type-char    = "t" | "x" | "f" | "d" | "c"
             | "h" | "s" | "a" | "H" | "S" | "C" ;
x-b36        = b36-digit ;
w-b36        = b36-digit ;
b36-digit    = digit | "a".."z" | "A".."Z" ;
digit        = "0".."9" ;

extras       = { any-char - EOL } ; (* type-specific, decoded per table below *)
suffix       = { any-char - EOL } ; (* currently only used by C-notes for interval *)

(* Type-specific extras:
   t  : (none)
   x  : ex-effect-char       ∈ { U,D,C,A,W,L,R,I }
   f  : (none)
   d  : (none)
   c  : (none)                (Click notes are discarded)
   h  : (none)                (parent; ends with child "s" line)
   s  : parent: (none)        (Slide parent)
        child:  joint-char    ∈ { C (control), D (step), E (end) }
   a  : dir-char , color-char
        dir    ∈ { U,D,N,L,R,K,J }  (see UgcPayload.AirDirectionChar)
        color  ∈ { N (normal), P (pink) }
   H  : height-b36             (AirHold; height is doubled)
   S  : height-b36 [ , joint ] (AirSlide; C=control, D=step)
   C  : color-char , height-b36 , "," , interval-int
        color  : UgcPayload.CrushColorChar (16 colors + transparent)
*)

ident        = { letter } ;
letter       = "A".."Z" | "a".."z" ;
field        = { any-char - TAB - EOL } ;
any-char     = ? any Unicode scalar ? ;
TAB          = ? U+0009 ? ;
EOL          = ? U+000A | U+000D U+000A ? ;
digits       = digit , { digit } ;
